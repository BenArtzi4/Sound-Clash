        "x": 0,
        "y": 1,
        "w": 5,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "thresholds",
            "fixedColor": "text"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 0.6,
                "color": "yellow"
              },
              {
                "value": 1.2,
                "color": "red"
